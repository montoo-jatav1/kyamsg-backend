# Copy this file to .env and fill in real values before running docker-compose up.

# Must be at least 32 characters — generate one with: openssl rand -base64 48
JWT_SECRET=

# Only needed once you plug in a real SMS provider (see LogOtpSender.java for how).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
